# Castellar — variables de entorno (ejemplo)
# Copia este archivo a .env y rellena los valores. NUNCA commitees .env real.

# ----- Postgres (dev local con docker-compose) -----
# El rol castellar_app respeta Row Level Security. Es el que usa Prisma en runtime.
DATABASE_URL="postgresql://castellar_app:castellar_app_dev@localhost:5432/castellar?schema=public"
# Rol superuser solo para migraciones (prisma migrate).
DATABASE_MIGRATE_URL="postgresql://castellar:castellar_dev@localhost:5432/castellar?schema=public"

# ----- Redis (Upstash en prod, local en dev) -----
REDIS_URL="redis://localhost:6379"

# ----- Supabase Auth (free tier en Supabase EU) -----
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""

# ----- Object storage (MinIO local en dev, Cloudflare R2 en prod) -----
S3_ENDPOINT="http://localhost:9000"
S3_REGION="eu-west-1"
S3_ACCESS_KEY="castellar"
S3_SECRET_KEY="castellar_dev"
S3_BUCKET="castellar-dev"
S3_FORCE_PATH_STYLE="true"

# ----- Email (Resend en prod, Mailhog en dev) -----
RESEND_API_KEY=""
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="no-reply@castellar.local"

# ----- Sentry (free tier) -----
SENTRY_DSN=""

# ----- Aplicación -----
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"
LOG_LEVEL="debug"
