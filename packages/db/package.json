{
  "name": "@castellar/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "tsx src/seed.ts",
    "build": "tsc",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:rls": "vitest run src/__tests__/rls.test.ts"
  },
  "dependencies": {
    "@castellar/core": "workspace:*",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@castellar/config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "@eslint/js": "^9.17.0",
    "eslint-plugin-security": "^3.0.1",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx src/seed.ts"
  }
}
